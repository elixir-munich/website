<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Elixir, Erlang & Gleam Munich">
      {assigns[:page_title]}
    </.live_title>
    <meta
      name="description"
      content="The official community for Elixir, Erlang & Gleam developers in Munich. Connect, learn and share knowledge with fellow BEAM enthusiasts."
    />
    <meta property="og:title" content="Elixir, Erlang & Gleam Munich" />
    <meta
      property="og:description"
      content="The official community for Elixir, Erlang & Gleam developers in Munich. Connect, learn and share knowledge with fellow BEAM enthusiasts."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://elixir-munich.org" />
    <meta property="og:site_name" content="Elixir, Erlang & Gleam Munich" />
    <meta property="og:image" content={~p"/images/elixir-munich-logo.svg"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Elixir, Erlang & Gleam Munich" />
    <meta
      name="twitter:description"
      content="The official community for Elixir, Erlang & Gleam developers in Munich. Connect, learn and share knowledge with fellow BEAM enthusiasts."
    />
    <meta name="twitter:image" content={~p"/images/elixir-munich-logo.svg"} />
    <link rel="icon" href={~p"/images/elixir-munich-logo.svg"} type="image/svg+xml" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        // Set dark theme by default
        document.documentElement.setAttribute("data-theme", "dark");
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
